<div
  class="loyaltypulse-widget-root"
  data-loyaltypulse-widget
  data-heading="{{ block.settings.heading | escape }}"
  data-login-message="{{ block.settings.login_message | escape }}"
  data-login-url="{{ routes.account_login_url }}"
  aria-live="polite"
>
  <div class="lpw-skeleton" data-lpw-loading>
    <div class="lpw-skeleton-header"></div>
    <div class="lpw-skeleton-body">
      <div class="lpw-skeleton-line lpw-skeleton-line--wide"></div>
      <div class="lpw-skeleton-line"></div>
      <div class="lpw-skeleton-line"></div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:loyalty_widget.name",
  "target": "section",
  "stylesheet": "loyalty-widget.css",
  "javascript": "loyalty-widget.js",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your Loyalty Rewards"
    },
    {
      "type": "textarea",
      "id": "login_message",
      "label": "Guest message",
      "default": "Log in to view your points balance and available rewards."
    }
  ]
}
{% endschema %}
