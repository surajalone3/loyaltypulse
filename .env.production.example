# LoyaltyPulse — Production / Railway environment variables
# Copy to Railway → Service → Variables (do NOT commit real secrets)

# ── Required at runtime ──────────────────────────────────────────────────────

# PostgreSQL connection string
# Source: Railway PostgreSQL plugin → Variables → DATABASE_URL
#         Or reference: ${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://user:password@host:5432/railway?schema=public

# Shopify Partner Dashboard → Apps → LoyaltyPulse → Client credentials
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=shpss_your_shopify_api_secret

# Must match shopify.app.toml [access_scopes]
SHOPIFY_SCOPES=read_orders,read_customers,write_discounts,write_app_proxy

# Public HTTPS URL of your Railway service (no trailing slash)
# Source: Railway → Service → Settings → Networking → Public domain
# Example: https://loyaltypulse-production.up.railway.app
HOST=https://your-app.up.railway.app

# ── Required at build time (Railway Variables) ───────────────────────────────

# Same value as SHOPIFY_API_KEY — baked into admin UI at vite build
VITE_SHOPIFY_API_KEY=your_shopify_api_key

# ── Railway / platform (recommended) ─────────────────────────────────────────

NODE_ENV=production

# Injected automatically by Railway — do not set manually unless testing locally
# PORT=3000

# ── Do NOT set in production ─────────────────────────────────────────────────

# DEV_MODE=true
# FRONTEND_PORT=5173
