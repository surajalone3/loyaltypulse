SHOPIFY_API_KEY=your_api_key_here
VITE_SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here
SHOPIFY_SCOPES=read_orders,read_customers,write_discounts,write_app_proxy
# Public HTTPS URL (ngrok/cloudflare) pointing at the BACKEND port — never localhost
HOST=https://your-tunnel-or-domain.example.com
DATABASE_URL=postgresql://user:password@localhost:5432/loyaltypulse?schema=public
PORT=3000
FRONTEND_PORT=5173
# Skip automatic ORDERS_PAID webhook registration during local development
DEV_MODE=true

# Theme App Extension / App Proxy:
# - Storefront widget: https://{shop}/apps/loyaltypulse/loyalty
# - Health check:     https://{HOST}/apps/loyaltypulse/health
#   curl -H "ngrok-skip-browser-warning: true" https://{HOST}/apps/loyaltypulse/health
#
# App Proxy dev workflow (recommended):
#   Terminal 1: npm run dev:frontend
#   Terminal 2: npm run dev:shopify
# `shopify app dev` uses a Cloudflare Quick Tunnel (no ngrok browser warning) and
# updates application_url + app_proxy URL on your dev store automatically.
#
# Manual ngrok (not recommended for App Proxy on free tier):
#   Terminal 1: ngrok http 3000
#   Terminal 2: npm run dev:backend
#   Terminal 3: npm run dev:frontend
#   Terminal 4: npm run dev:shopify:ngrok
# ngrok free cannot inject ngrok-skip-browser-warning for Shopify's server-side proxy.
