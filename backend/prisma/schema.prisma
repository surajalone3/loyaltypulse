generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Shopify OAuth sessions (@shopify/shopify-app-session-storage-prisma)
// ---------------------------------------------------------------------------
model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
  createdAt           DateTime  @default(now())

  @@index([shop])
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------
enum Plan {
  FREE
  GROWTH
  PRO
  ENTERPRISE
}

enum CustomerTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum PointsTransactionType {
  EARNED
  REDEEMED
  BONUS
}

enum ReferralStatus {
  PENDING
  COMPLETED
}

enum ReviewRequestStatus {
  PENDING
  SENT
  COMPLETED
}

enum RewardDiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

// ---------------------------------------------------------------------------
// Merchant store
// ---------------------------------------------------------------------------
model Store {
  id          String   @id @default(cuid())
  shop        String   @unique
  accessToken String
  plan        Plan     @default(FREE)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  loyaltyProgram    LoyaltyProgram?
  loyaltyTiers      LoyaltyTier[]
  customers         Customer[]
  pointsTransactions PointsTransaction[]
  upsellOffers      UpsellOffer[]
  upsellConversions UpsellConversion[]
  reviewRequests    ReviewRequest[]
  rewards           Reward[]
  referrals         Referral[]
}

// ---------------------------------------------------------------------------
// Loyalty program settings (one per store)
// ---------------------------------------------------------------------------
model LoyaltyProgram {
  id               String  @id @default(cuid())
  storeId          String  @unique
  programName      String  @default("Stars")
  pointsPerDollar  Int     @default(10)
  rewardThreshold  Int     @default(100)
  pointsName       String  @default("points")
  welcomeBonus     Int     @default(0)
  referralBonus    Int     @default(0)
  reviewRequestDelayDays Int @default(7)
  reviewRequestsEnabled  Boolean @default(true)
  isActive         Boolean @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

// ---------------------------------------------------------------------------
// Configurable loyalty tiers (per store)
// ---------------------------------------------------------------------------
model LoyaltyTier {
  id                  String       @id @default(cuid())
  storeId             String
  tierKey             CustomerTier
  name                String
  minLifetimeSpend    Decimal      @default(0) @db.Decimal(12, 2)
  color               String       @default("#CD7F32")
  benefitsDescription String       @default("")
  enabled             Boolean      @default(true)
  sortOrder           Int          @default(0)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, tierKey])
  @@index([storeId])
}

// ---------------------------------------------------------------------------
// Loyalty members
// ---------------------------------------------------------------------------
model Customer {
  id                 String       @id @default(cuid())
  storeId            String
  shopifyCustomerId  String
  email              String?
  firstName          String?
  lastName           String?
  totalPoints        Int          @default(0)
  lifetimePoints     Int          @default(0)
  lifetimeSpend      Decimal      @default(0) @db.Decimal(12, 2)
  tier               CustomerTier @default(BRONZE)
  referralCode       String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  store              Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  pointsTransactions PointsTransaction[]
  upsellConversions  UpsellConversion[]
  reviewRequests     ReviewRequest[]
  redemptions        Redemption[]
  referralsMade      Referral[]          @relation("ReferralsMade")
  referralReceived   Referral?           @relation("ReferralsReceived")

  @@unique([storeId, shopifyCustomerId])
  @@unique([storeId, referralCode])
  @@index([storeId])
  @@index([storeId, tier])
  @@index([email])
}

// ---------------------------------------------------------------------------
// Customer referrals
// ---------------------------------------------------------------------------
model Referral {
  id                 String         @id @default(cuid())
  storeId            String
  referrerCustomerId String
  referredCustomerId String         @unique
  referralCode       String
  status             ReferralStatus @default(PENDING)
  rewardIssued       Boolean        @default(false)
  createdAt          DateTime       @default(now())

  store            Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  referrerCustomer Customer @relation("ReferralsMade", fields: [referrerCustomerId], references: [id], onDelete: Cascade)
  referredCustomer Customer @relation("ReferralsReceived", fields: [referredCustomerId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([referrerCustomerId])
  @@index([status])
  @@index([referralCode])
}

// ---------------------------------------------------------------------------
// Points ledger
// ---------------------------------------------------------------------------
model PointsTransaction {
  id         String                @id @default(cuid())
  customerId String
  storeId    String
  type       PointsTransactionType
  points     Int
  reason     String?
  orderId    String?
  createdAt  DateTime              @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([storeId])
  @@index([storeId, createdAt])
  @@index([orderId])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Redeemable rewards (merchant-defined)
// ---------------------------------------------------------------------------
model Reward {
  id              String             @id @default(cuid())
  storeId         String
  name            String
  description     String?
  pointsRequired  Int
  discountType    RewardDiscountType @default(PERCENTAGE)
  discountValue   Decimal            @default(10) @db.Decimal(10, 2)
  isActive        Boolean            @default(true)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  store       Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  redemptions Redemption[]

  @@index([storeId])
  @@index([storeId, isActive])
}

// ---------------------------------------------------------------------------
// Reward redemptions (storefront coupon codes)
// ---------------------------------------------------------------------------
model Redemption {
  id                String             @id @default(cuid())
  customerId        String
  rewardId          String
  pointsSpent       Int
  couponCode        String             @unique
  shopifyDiscountId String?
  discountType      RewardDiscountType
  discountValue     Decimal            @db.Decimal(10, 2)
  createdAt         DateTime           @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  reward   Reward   @relation(fields: [rewardId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([rewardId])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Upsell offers
// ---------------------------------------------------------------------------
model UpsellOffer {
  id               String   @id @default(cuid())
  storeId          String
  productId        String
  productTitle     String
  originalPrice    Decimal  @db.Decimal(10, 2)
  discountedPrice  Decimal  @db.Decimal(10, 2)
  discountPercent  Int
  isActive         Boolean  @default(true)
  position         Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  store       Store              @relation(fields: [storeId], references: [id], onDelete: Cascade)
  conversions UpsellConversion[]

  @@index([storeId])
  @@index([storeId, isActive])
}

// ---------------------------------------------------------------------------
// Upsell conversion tracking
// ---------------------------------------------------------------------------
model UpsellConversion {
  id         String   @id @default(cuid())
  storeId    String
  offerId    String
  orderId    String
  customerId String?
  accepted   Boolean
  revenue    Decimal  @default(0) @db.Decimal(10, 2)
  createdAt  DateTime @default(now())

  store    Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  offer    UpsellOffer  @relation(fields: [offerId], references: [id], onDelete: Cascade)
  customer Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([storeId])
  @@index([offerId])
  @@index([orderId])
  @@index([customerId])
}

// ---------------------------------------------------------------------------
// Review request emails
// ---------------------------------------------------------------------------
model ReviewRequest {
  id              String              @id @default(cuid())
  storeId         String
  orderId         String
  customerId      String?
  email           String
  status          ReviewRequestStatus @default(PENDING)
  scheduledSendAt DateTime?
  sentAt          DateTime?
  reviewedAt      DateTime?
  pointsAwarded   Int                 @default(0)
  createdAt       DateTime            @default(now())

  store    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@unique([storeId, orderId])
  @@index([storeId])
  @@index([storeId, status])
  @@index([status, scheduledSendAt])
  @@index([orderId])
  @@index([customerId])
  @@index([email])
  @@index([scheduledSendAt])
}
